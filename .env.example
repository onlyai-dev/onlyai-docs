# Keystatic CMS – GitHub mode (production / preview)
# Copy to .env locally. On Vercel, set the same keys in Project → Settings → Environment Variables.
# See: https://keystatic.com/docs/github-mode
#
# GitHub App: add this exact callback URL under the app’s settings:
#   https://docs.onlyai.world/api/keystatic/github/oauth/callback
#
# Required for Keystatic’s token handler: enable expiring user tokens on the GitHub App
# (Developer settings → GitHub Apps → your app → Optional features → opt in to
# “User-to-server token expiration”). Otherwise the token response has no refresh_token
# and sign-in fails at /api/keystatic/github/oauth/callback.

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
# Astro / Vite: expose the app slug from the Keystatic GitHub App setup (if you use it).
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
